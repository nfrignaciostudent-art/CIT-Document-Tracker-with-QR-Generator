{
  "name": "idea-cit-document-tracker",
  "version": "1.0.0",
  "description": "IDEA CIT Document Tracker Project",
  "workspaces": [
    "backend",
    "Frontend"
  ],
  "scripts": {
    "install-all": "npm install",
